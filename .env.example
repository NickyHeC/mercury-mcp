# =============================================================================
# Environment Variables for Mercury MCP Server
# =============================================================================
# Copy this file:  cp .env.example .env
# Then fill in the values below.

# =============================================================================
# Dedalus Platform (required for DAuth)
# =============================================================================

DEDALUS_AS_URL=https://as.dedaluslabs.ai
DEDALUS_API_KEY=

# =============================================================================
# Mercury API Key Auth
# =============================================================================
# Your Mercury API token (format: secret-token:mercury_production_...)
# Must match the SecretKeys(token="...") value in src/main.py.

MERCURY_TOKEN=
